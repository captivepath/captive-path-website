---
import Layout from '../layouts/Layout.astro';
import Hero from '../components/Hero.astro';
import CredibilityStrip from '../components/CredibilityStrip.astro';
import WhatWeDo from '../components/WhatWeDo.astro';
import HowItWorks from '../components/HowItWorks.astro';
import WhyZach from '../components/WhyZach.astro';
import ClosingCTA from '../components/ClosingCTA.astro';

const organizationSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://captivepath.com/#organization",
      "name": "Captive Path",
      "url": "https://captivepath.com",
      "logo": {
        "@type": "ImageObject",
        "url": "https://captivepath.com/images/cp-logo-black.webp"
      },
      "description": "An independent venture platform built to evaluate, shape, and advance selected opportunities through strategy, systems, and modern execution.",
      "founder": {
        "@type": "Person",
        "@id": "https://captivepath.com/#zach-warshawsky",
        "name": "Zach Warshawsky",
        "jobTitle": "Founder",
        "url": "https://captivepath.com/about/",
        "sameAs": ["https://www.linkedin.com/in/zachwarshawsky/"]
      },
      "sameAs": ["https://www.linkedin.com/company/captivepath"]
    },
    {
      "@type": "WebSite",
      "@id": "https://captivepath.com/#website",
      "url": "https://captivepath.com",
      "name": "Captive Path",
      "publisher": { "@id": "https://captivepath.com/#organization" }
    }
  ]
});

const faqSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is Captive Path?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Captive Path is an independent venture platform built to evaluate, shape, and advance selected opportunities. It operates at the intersection of strategy, systems, and execution... providing the infrastructure and operator involvement that early-stage ventures need to move from idea to reality."
      }
    },
    {
      "@type": "Question",
      "name": "Is Captive Path a venture studio?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Captive Path operates similarly to a venture studio in that it builds ventures from the inside rather than investing from the outside. The distinction is that involvement is highly selective and operator-led. Captive Path does not run a portfolio model. It engages deeply with a small number of opportunities at a time."
      }
    },
    {
      "@type": "Question",
      "name": "Who is Captive Path for?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Captive Path works with founders, operators, and early-stage ventures where the opportunity is real but the infrastructure, strategy, or execution capacity is the limiting factor. It is not for every idea. It is for the ones worth building seriously."
      }
    },
    {
      "@type": "Question",
      "name": "How does the Captive Path process work?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Every engagement begins with evaluation... an honest assessment of the opportunity, the market, and the fit. From there, Captive Path shapes the strategy, builds the right foundation, and advances the venture through structured execution."
      }
    },
    {
      "@type": "Question",
      "name": "How do I get in touch with Captive Path?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Use the contact page at https://captivepath.com/contact/ to start a conversation. Responses are reviewed personally. If the opportunity is worth exploring, the conversation will reflect that."
      }
    }
  ]
});
---

<Layout
  title="Captive Path | Venture Platform for Serious Venture Building"
  description="Captive Path is an independent venture platform led by Zach Warshawsky, built to evaluate, shape, and advance selected ventures through strategy, systems, and modern execution."
  ogTitle="Captive Path | Venture Platform for Serious Venture Building"
  ogDescription="Captive Path is an independent venture platform led by Zach Warshawsky, built to evaluate, shape, and advance selected ventures through strategy, systems, and modern execution."
  ogUrl="https://captivepath.com/"
  ogImage="https://captivepath.com/og/pages/og-home.png"
  ogImageAlt="Captive Path: A venture platform for what's worth building"
  twitterTitle="Captive Path | Venture Platform for Serious Venture Building"
  twitterDescription="Captive Path is an independent venture platform led by Zach Warshawsky, built to evaluate, shape, and advance selected ventures through strategy, systems, and modern execution."
  twitterImage="https://captivepath.com/og/pages/og-home.png"
  canonicalUrl="https://captivepath.com/"
  jsonLd={[organizationSchema, faqSchema]}
>
  <Hero />
  <CredibilityStrip />

  <!-- Entity Clarifier Block -->
  <section class="py-16 md:py-20 section-fade-in">
    <div class="max-w-6xl mx-auto px-6 md:px-10">
      <div class="reveal max-w-3xl">
        <p class="font-display text-2xl md:text-3xl text-graphite-900 leading-snug font-bold mb-4">
          Captive Path is a venture platform.
        </p>
        <p class="text-graphite-600 text-lg leading-relaxed mb-4">
          Not an agency. Not a fund. Not a consulting firm.
        </p>
        <p class="text-graphite-600 text-lg leading-relaxed">
          It is an independent, <a href="/about/" class="text-teal-800 hover:text-teal-700 transition-colors link-underline">operator-led platform</a> that evaluates selected opportunities and provides the strategy, systems, and execution infrastructure needed to build them into real ventures. Involvement is selective. When Captive Path engages, it engages fully.
        </p>
      </div>
    </div>
  </section>

  <WhatWeDo condensed />
  <HowItWorks condensed />
  <WhyZach />

  <!-- FAQ Section -->
  <section class="py-22 md:py-30 border-t border-stone-200 section-fade-in">
    <div class="max-w-6xl mx-auto px-6 md:px-10">
      <div class="max-w-3xl">
        <p class="reveal text-xs font-display font-medium tracking-widest uppercase text-teal-800 mb-4">
          Frequently asked questions
        </p>
        <h2 class="reveal font-display text-3xl md:text-4xl text-graphite-900 leading-tight font-bold mb-12">
          Common questions about Captive Path.
        </h2>

        <div class="reveal-stagger space-y-8">
          <div class="reveal">
            <h3 class="font-display font-semibold text-graphite-900 text-lg mb-3">What is Captive Path?</h3>
            <p class="text-graphite-600 text-base leading-relaxed">Captive Path is an independent venture platform built to evaluate, shape, and advance selected opportunities. It operates at the intersection of strategy, systems, and execution... providing the infrastructure and operator involvement that early-stage ventures need to move from idea to reality.</p>
          </div>

          <div class="reveal">
            <h3 class="font-display font-semibold text-graphite-900 text-lg mb-3">Is Captive Path a venture studio?</h3>
            <p class="text-graphite-600 text-base leading-relaxed">Captive Path operates similarly to a venture studio in that it builds ventures from the inside rather than investing from the outside. The distinction is that involvement is highly selective and operator-led. Captive Path does not run a portfolio model. It engages deeply with a small number of opportunities at a time.</p>
          </div>

          <div class="reveal">
            <h3 class="font-display font-semibold text-graphite-900 text-lg mb-3">Who is Captive Path for?</h3>
            <p class="text-graphite-600 text-base leading-relaxed">Captive Path works with founders, operators, and early-stage ventures where the opportunity is real but the infrastructure, strategy, or execution capacity is the limiting factor. It is not for every idea. It is for the ones worth building seriously.</p>
          </div>

          <div class="reveal">
            <h3 class="font-display font-semibold text-graphite-900 text-lg mb-3">How does the process work?</h3>
            <p class="text-graphite-600 text-base leading-relaxed">Every engagement begins with evaluation... an honest assessment of the opportunity, the market, and the fit. From there, Captive Path shapes the strategy, builds the right foundation, and advances the venture through structured execution. The full process is described on the <a href="/process/" class="text-teal-800 hover:text-teal-700 transition-colors link-underline">Process page</a>.</p>
          </div>

          <div class="reveal">
            <h3 class="font-display font-semibold text-graphite-900 text-lg mb-3">How do I get in touch?</h3>
            <p class="text-graphite-600 text-base leading-relaxed">Use the <a href="/contact/" class="text-teal-800 hover:text-teal-700 transition-colors link-underline">contact page</a> to start a conversation. Responses are reviewed personally. If the opportunity is worth exploring, the conversation will reflect that.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <ClosingCTA />
</Layout>
