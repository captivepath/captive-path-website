---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths = (async ({ paginate }) => {
  const allArticles = await getCollection('journal');
  const publishedArticles = allArticles
    .filter((a) => a.data.published)
    .sort((a, b) => {
      const dateA = a.data.publish_date || a.data.date || '';
      const dateB = b.data.publish_date || b.data.date || '';
      return dateB.localeCompare(dateA);
    });
  return paginate(publishedArticles, { pageSize: 6 });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
const categories = ['All', 'Venture Analysis', 'Venture Evaluation', 'Strategy', 'Execution and Strategy', 'Incubation', 'Venture Models', 'Captive Path Perspective'];
const pageNum = page.currentPage;
const pageTitle = pageNum > 1
  ? `Captive Path Journal — Page ${pageNum} | Venture Strategy and Operator Insights`
  : 'Captive Path Journal | Venture Strategy and Operator Insights';
const canonicalUrl = pageNum > 1
  ? `https://captivepath.com/journal/${pageNum}/`
  : 'https://captivepath.com/journal/';
---

<Layout
  title={pageTitle}
  description="Read Captive Path's journal on venture evaluation, incubation models, strategy, systems, and the practical work of building ventures that matter."
  ogTitle="Captive Path Journal | Venture Strategy and Operator Insights"
  ogDescription="Read Captive Path's journal on venture evaluation, incubation models, strategy, systems, and the practical work of building ventures that matter."
  ogUrl="https://captivepath.com/journal/"
  ogImage="https://captivepath.com/og/pages/og-journal.png"
  ogImageAlt="Captive Path Journal — Ideas, analysis, operating perspective"
  twitterTitle="Captive Path Journal | Venture Strategy and Operator Insights"
  twitterDescription="Read Captive Path's journal on venture evaluation, incubation models, strategy, systems, and the practical work of building ventures that matter."
  twitterImage="https://captivepath.com/og/pages/og-journal.png"
  canonicalUrl={canonicalUrl}
>
  <!-- Hero -->
  <section class="pt-32 pb-16 md:pt-40 md:pb-20 section-fade-in">
    <div class="max-w-6xl mx-auto px-6 md:px-10">
      <p class="reveal text-xs font-display font-medium tracking-widest uppercase text-teal-800 mb-4">
        Journal
      </p>
      <h1 class="reveal font-display text-4xl sm:text-5xl md:text-6xl text-graphite-900 leading-tight font-bold mb-6 max-w-3xl">
        Ideas, analysis and operating <span class="text-highlight">perspective.</span>
      </h1>
      <p class="reveal text-graphite-600 text-lg md:text-xl leading-relaxed max-w-2xl">
        Writing on venture evaluation, strategy, incubation and the work of
        building things that matter.
      </p>
    </div>
  </section>

  <!-- Article Cards -->
  <section class="pt-10 md:pt-14 pb-22 md:pb-30">
    <div class="max-w-6xl mx-auto px-6 md:px-10">
      <!-- Category filters -->
      <div class="reveal flex flex-wrap gap-3 mb-12 md:mb-16" id="journal-filters">
        {categories.map((cat) => (
          <button
            data-category={cat}
            class:list={[
              'journal-filter px-4 py-2 text-sm font-medium rounded-sm transition-colors duration-200 cursor-pointer',
              cat === 'All'
                ? 'bg-graphite-900 text-stone-50'
                : 'bg-stone-100 text-graphite-600 hover:bg-stone-200',
            ]}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Article cards with thumbnails -->
      <div class="reveal-stagger grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-10" id="journal-articles">
        {page.data.map((article) => (
          <article class="reveal group journal-card" data-category={article.data.category}>
            <a href={`/journal/${article.id}/`} class="block mb-5">
              <img
                src={article.data.og_image || `/og/journal/${article.id}.png`}
                alt={article.data.title}
                class="w-full aspect-[1200/630] object-cover rounded-sm"
                width="1200"
                height="630"
                loading="lazy"
              />
            </a>
            <div>
              <span class="text-xs font-display font-medium tracking-wider uppercase text-teal-800 mb-2 block">
                {article.data.category}
              </span>
              <a href={`/journal/${article.id}/`}>
                <h2 class="font-display text-xl md:text-2xl font-semibold text-graphite-900 leading-snug mb-3 group-hover:text-teal-800 transition-colors">
                  {article.data.title}
                </h2>
              </a>
              <p class="text-graphite-500 text-base leading-relaxed mb-4">
                {article.data.excerpt}
              </p>
              <a
                href={`/journal/${article.id}/`}
                class="text-sm font-medium text-teal-800 hover:text-teal-700 transition-colors link-underline"
              >
                Read the article →
              </a>
            </div>
          </article>
        ))}
      </div>

      <!-- Pagination -->
      {page.lastPage > 1 && (
        <nav class="reveal mt-16 flex items-center justify-center gap-4" aria-label="Journal pagination">
          {page.url.prev ? (
            <a
              href={page.url.prev}
              class="px-4 py-2 text-sm font-medium text-graphite-600 bg-stone-100 hover:bg-stone-200 rounded-sm transition-colors"
            >
              ← Previous
            </a>
          ) : (
            <span class="px-4 py-2 text-sm font-medium text-stone-300 cursor-default">← Previous</span>
          )}

          <span class="text-sm text-graphite-500">
            Page {page.currentPage} of {page.lastPage}
          </span>

          {page.url.next ? (
            <a
              href={page.url.next}
              class="px-4 py-2 text-sm font-medium text-graphite-600 bg-stone-100 hover:bg-stone-200 rounded-sm transition-colors"
            >
              Next →
            </a>
          ) : (
            <span class="px-4 py-2 text-sm font-medium text-stone-300 cursor-default">Next →</span>
          )}
        </nav>
      )}

      <!-- Internal link -->
      <div class="reveal mt-16 text-center">
        <a
          href="/contact"
          class="text-sm font-medium text-teal-800 hover:text-teal-700 transition-colors link-underline"
        >
          Have something worth exploring? Start a conversation →
        </a>
      </div>
    </div>
  </section>

  <script>
    function initFilters() {
      const buttons = document.querySelectorAll<HTMLButtonElement>('.journal-filter');
      const cards = document.querySelectorAll<HTMLElement>('.journal-card');

      buttons.forEach((btn) => {
        btn.addEventListener('click', () => {
          const selected = btn.dataset.category || 'All';

          buttons.forEach((b) => {
            if (b.dataset.category === selected) {
              b.className = b.className
                .replace('bg-stone-100 text-graphite-600 hover:bg-stone-200', '')
                .replace('bg-graphite-900 text-stone-50', '') + ' bg-graphite-900 text-stone-50';
            } else {
              b.className = b.className
                .replace('bg-graphite-900 text-stone-50', '')
                .replace('bg-stone-100 text-graphite-600 hover:bg-stone-200', '') + ' bg-stone-100 text-graphite-600 hover:bg-stone-200';
            }
          });

          cards.forEach((card) => {
            if (selected === 'All' || card.dataset.category === selected) {
              card.style.display = '';
            } else {
              card.style.display = 'none';
            }
          });
        });
      });
    }

    document.addEventListener('astro:page-load', initFilters);
    initFilters();
  </script>
</Layout>
