---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const articles = await getCollection('journal');
const categories = ['All', 'Venture Analysis', 'Strategy', 'Incubation'];
---

<Layout title="Journal — Captive Path" description="Ideas, analysis, and operating perspective. Writing on venture evaluation, strategy, incubation, and the work of building things that matter.">
  <!-- Hero -->
  <section class="pt-32 pb-16 md:pt-40 md:pb-20 section-fade-in">
    <div class="max-w-6xl mx-auto px-6 md:px-10">
      <p class="reveal text-xs font-display font-medium tracking-widest uppercase text-teal-800 mb-4">
        Journal
      </p>
      <h1 class="reveal font-display text-4xl sm:text-5xl md:text-6xl text-graphite-900 leading-tight font-bold mb-6 max-w-3xl">
        Ideas, analysis and operating <span class="text-highlight">perspective.</span>
      </h1>
      <p class="reveal text-graphite-600 text-lg md:text-xl leading-relaxed max-w-2xl">
        Writing on venture evaluation, strategy, incubation and the work of
        building things that matter.
      </p>
    </div>
  </section>

  <!-- Article List -->
  <section class="pt-10 md:pt-14 pb-22 md:pb-30">
    <div class="max-w-6xl mx-auto px-6 md:px-10">
      <!-- Category filters -->
      <div class="reveal flex flex-wrap gap-3 mb-12 md:mb-16">
        {categories.map((cat) => (
          <button
            class:list={[
              'px-4 py-2 text-sm font-medium rounded-sm transition-colors duration-200',
              cat === 'All'
                ? 'bg-graphite-900 text-stone-50'
                : 'bg-stone-100 text-graphite-600 hover:bg-stone-200',
            ]}
          >
            {cat}
          </button>
        ))}
      </div>

      <!-- Article cards -->
      <div class="reveal-stagger space-y-0">
        {articles.map((article, i) => (
          <article
            class:list={[
              'reveal group py-10 md:py-12',
              i < articles.length - 1 ? 'border-b border-stone-200' : '',
              i === 0 ? 'border-t border-stone-200' : '',
            ]}
          >
            <div class="flex flex-col md:flex-row md:items-start gap-4 md:gap-10">
              <div class="md:w-36 shrink-0">
                <span class="text-xs font-display font-medium tracking-wider uppercase text-teal-800">
                  {article.data.category}
                </span>
                <p class="text-sm text-graphite-400 mt-1">{article.data.date}</p>
              </div>
              <div class="flex-1">
                {article.data.published ? (
                  <a href={`/journal/${article.id}`}>
                    <h2 class="font-display text-2xl md:text-3xl font-semibold text-graphite-900 leading-snug mb-3 group-hover:text-teal-800 transition-colors">
                      {article.data.title}
                    </h2>
                  </a>
                ) : (
                  <h2 class="font-display text-2xl md:text-3xl font-semibold text-graphite-900 leading-snug mb-3">
                    {article.data.title}
                  </h2>
                )}
                <p class="text-graphite-500 text-base leading-relaxed max-w-2xl">
                  {article.data.excerpt}
                </p>
              </div>
            </div>
          </article>
        ))}
      </div>

      <!-- More coming soon -->
      <div class="reveal mt-16 text-center">
        <div class="inline-flex items-center gap-3 px-6 py-3 bg-stone-100 rounded-sm">
          <div class="w-2 h-2 bg-teal-600 rounded-full animate-pulse"></div>
          <p class="text-sm font-medium text-graphite-600">
            More articles coming soon
          </p>
        </div>
      </div>
    </div>
  </section>
</Layout>
