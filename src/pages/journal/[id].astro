---
import Layout from '../../layouts/Layout.astro';
import RelatedReading from '../../components/RelatedReading.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const articles = await getCollection('journal', ({ data }) => data.published);
  return articles.map((article) => ({
    params: { id: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const canonicalUrl = article.data.canonical_url || `https://captivepath.com/journal/${article.id}/`;
const ogImage = article.data.og_image
  ? `https://captivepath.com${article.data.og_image}`
  : `https://captivepath.com/og/journal/${article.id}.png`;
const twitterImage = article.data.twitter_image
  ? `https://captivepath.com${article.data.twitter_image}`
  : ogImage;

const articleSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": article.data.title,
  "description": article.data.meta_description || article.data.excerpt,
  "url": canonicalUrl,
  "datePublished": article.data.publish_date || "2026-04-26",
  "dateModified": article.data.publish_date || "2026-04-26",
  "author": {
    "@type": "Person",
    "@id": "https://captivepath.com/#zach-warshawsky",
    "name": article.data.author || "Zach Warshawsky"
  },
  "publisher": { "@id": "https://captivepath.com/#organization" },
  "image": ogImage,
  "isPartOf": { "@id": "https://captivepath.com/#website" }
});

// FAQPage schema for the comparison article (T-206)
const comparisonSlug = 'venture-platform-vs-venture-studio-what-actually-changes-operationally';
const faqSchema = article.id === comparisonSlug ? JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the operational difference between a venture platform and a venture studio?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A venture studio runs a portfolio. It originates many ideas and pushes a meaningful number of them forward in parallel. A venture platform engages with a small number of opportunities at a time and goes deeper on each. Operationally that means different staffing models, different sequencing of work and different decision rights for founders."
      }
    },
    {
      "@type": "Question",
      "name": "Which model gives founders more control over equity and direction?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "A platform engagement is structured around the specific opportunity. Direction and equity are negotiated case by case rather than flowing from a portfolio model that treats every venture similarly. For founders who need real involvement without giving up the company, a platform tends to fit better."
      }
    },
    {
      "@type": "Question",
      "name": "When is a venture platform a better fit than a venture studio?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "When the opportunity is real but the path from idea to execution is unclear and when the founder needs structured involvement from someone who has built systems and businesses before. A platform is built for that specific situation. A studio is built for portfolio scale."
      }
    },
    {
      "@type": "Question",
      "name": "Does a venture platform replace traditional advisors?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It replaces the parts of advisory work that need execution, judgment and accountability. It does not replace specialist advisors for narrow domains like tax or regulatory law. The line is whether the work needs to be done or only discussed."
      }
    }
  ]
}) : undefined;

const jsonLdBlocks = [articleSchema, faqSchema].filter(Boolean);
---

<Layout
  title={article.data.meta_title || `${article.data.title} | Captive Path`}
  description={article.data.meta_description || article.data.excerpt}
  ogTitle={article.data.og_title || article.data.title}
  ogDescription={article.data.og_description || article.data.excerpt}
  ogUrl={canonicalUrl}
  ogImage={ogImage}
  ogImageAlt={article.data.og_image_alt || `${article.data.title} — Captive Path Journal`}
  twitterTitle={article.data.twitter_title || article.data.title}
  twitterDescription={article.data.twitter_description || article.data.excerpt}
  twitterImage={twitterImage}
  canonicalUrl={canonicalUrl}
  ogType="article"
  jsonLd={jsonLdBlocks}
>
  <article class="pt-32 pb-20 md:pt-40 md:pb-26">
    <div class="max-w-3xl mx-auto px-6 md:px-10">
      <a
        href="/journal/"
        class="text-sm font-medium text-teal-800 hover:text-teal-700 transition-colors link-underline mb-8 inline-block"
      >
        ← Journal
      </a>

      <div class="mb-6">
        <span class="text-xs font-display font-medium tracking-wider uppercase text-teal-800">
          {article.data.category}
        </span>
      </div>

      <h1 class="font-display text-4xl sm:text-5xl text-graphite-900 leading-tight font-bold mb-4">
        {article.data.title}
      </h1>

      <div class="flex items-center gap-3 mb-10">
        <img
          src="/images/zach-warshawsky-avatar.webp"
          alt="Zach Warshawsky"
          class="w-8 h-8 rounded-full object-cover"
          width="32"
          height="32"
        />
        <p class="text-graphite-500 text-sm">
          By {article.data.author || 'Zach Warshawsky'}
        </p>
      </div>

      <div class="prose prose-stone max-w-none text-graphite-700 leading-relaxed">
        <Content />
      </div>

      <RelatedReading currentId={article.id} />

      <!-- Internal links -->
      <div class="mt-14 pt-8 border-t border-stone-200 flex flex-col sm:flex-row gap-4">
        <a href="/process/" class="text-sm font-medium text-teal-800 hover:text-teal-700 transition-colors link-underline">
          See how Captive Path evaluates ventures →
        </a>
        <a href="/contact/" class="text-sm font-medium text-teal-800 hover:text-teal-700 transition-colors link-underline">
          Start a conversation →
        </a>
      </div>
    </div>
  </article>
</Layout>
