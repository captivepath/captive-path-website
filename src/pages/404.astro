---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found | Captive Path"
  description="The page you are looking for does not exist."
  noindex={true}
>
  <section class="min-h-[80vh] flex items-center section-fade-in">
    <div class="max-w-3xl mx-auto px-6 md:px-10 text-center py-20">
      <img
        src="/images/captive-path-404-robot.png"
        alt=""
        role="presentation"
        class="reveal mx-auto mb-10 w-64 sm:w-80 md:w-96 h-auto"
        width="960"
        height="540"
      />
      <h1 class="reveal font-display text-6xl sm:text-7xl md:text-8xl font-bold leading-none mb-4">
        <span class="text-highlight">404</span>
      </h1>
      <p class="reveal font-display text-2xl sm:text-3xl md:text-4xl text-graphite-900 font-bold leading-tight mb-6">
        Page not found.
      </p>
      <p class="reveal text-graphite-600 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto mb-10">
        The page you are looking for does not exist or has been moved.
      </p>
      <div class="reveal flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center px-7 py-3.5 bg-teal-800 text-stone-50 text-sm font-medium tracking-wide rounded hover:bg-teal-700 transition-all duration-200 hover:shadow-lg hover:shadow-teal-900/20"
        >
          Back to Home
        </a>
        <a
          href="/journal/"
          class="inline-flex items-center justify-center px-7 py-3.5 border border-graphite-800 text-graphite-800 text-sm font-medium tracking-wide rounded hover:bg-graphite-800 hover:text-stone-50 transition-all duration-200"
        >
          Read the Journal
        </a>
      </div>
    </div>
  </section>
</Layout>
