---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Page Not Found | Captive Path"
  description="The page you are looking for does not exist."
  noindex={true}
>
  <section class="h-dvh flex items-start justify-center section-fade-in pt-24 md:pt-28">
    <div class="max-w-6xl mx-auto px-6 md:px-10 text-center mt-[8vh]">
      <img
        src="/images/captive-path-404-robot.png"
        alt=""
        role="presentation"
        class="reveal mx-auto mb-6 w-80 sm:w-[28rem] md:w-[36rem] h-auto"
        width="960"
        height="540"
      />
      <h1 class="reveal font-display text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold leading-none mb-4 sm:whitespace-nowrap">
        <span class="text-highlight">404</span> Page not found.
      </h1>
      <p class="reveal text-graphite-600 text-lg md:text-xl leading-relaxed max-w-2xl mx-auto mb-6">
        This page clearly lost its path…
      </p>
      <div class="reveal flex flex-col sm:flex-row gap-4 justify-center">
        <a
          href="/"
          class="inline-flex items-center justify-center px-7 py-3.5 bg-teal-800 text-stone-50 text-sm font-medium tracking-wide rounded hover:bg-teal-700 transition-all duration-200 hover:shadow-lg hover:shadow-teal-900/20"
        >
          Back to Home
        </a>
        <a
          href="/journal/"
          class="inline-flex items-center justify-center px-7 py-3.5 border border-graphite-800 text-graphite-800 text-sm font-medium tracking-wide rounded hover:bg-graphite-800 hover:text-stone-50 transition-all duration-200"
        >
          Read the Journal
        </a>
      </div>
    </div>
  </section>
</Layout>
