---
import Layout from '../layouts/Layout.astro';
import WhatWeDo from '../components/WhatWeDo.astro';
import WhoItsFor from '../components/WhoItsFor.astro';
import FocusAreas from '../components/FocusAreas.astro';
import ClosingCTA from '../components/ClosingCTA.astro';

const aboutSchema = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "AboutPage",
      "@id": "https://captivepath.com/about/#webpage",
      "url": "https://captivepath.com/about/",
      "name": "About Captive Path | Operator-Led Venture Platform",
      "description": "Learn about Captive Path, an independent venture platform led by Zach Warshawsky and built for venture evaluation, strategic clarity, and serious execution.",
      "isPartOf": { "@id": "https://captivepath.com/#website" },
      "about": { "@id": "https://captivepath.com/#organization" }
    },
    {
      "@type": "Person",
      "@id": "https://captivepath.com/#zach-warshawsky",
      "name": "Zach Warshawsky",
      "jobTitle": "Founder",
      "worksFor": { "@id": "https://captivepath.com/#organization" },
      "url": "https://captivepath.com/about/",
      "description": "Entrepreneur, operator, and systems thinker with 20+ years building and scaling technology and marketing businesses. Co-founder of Profitable Media. Founder of Captive Path.",
      "sameAs": ["https://www.linkedin.com/in/zachwarshawsky/"]
    }
  ]
});
---

<Layout
  title="About Captive Path | Operator-Led Venture Platform"
  description="Learn about Captive Path, an independent venture platform led by Zach Warshawsky and built for venture evaluation, strategic clarity, and serious execution."
  ogTitle="About Captive Path | Operator-Led Venture Platform"
  ogDescription="Learn about Captive Path, an independent venture platform led by Zach Warshawsky and built for venture evaluation, strategic clarity, and serious execution."
  ogUrl="https://captivepath.com/about/"
  ogImage="https://captivepath.com/og/pages/og-about.png"
  ogImageAlt="About Captive Path — Built for the work between vision and execution"
  twitterTitle="About Captive Path | Operator-Led Venture Platform"
  twitterDescription="Learn about Captive Path, an independent venture platform led by Zach Warshawsky and built for venture evaluation, strategic clarity, and serious execution."
  twitterImage="https://captivepath.com/og/pages/og-about.png"
  canonicalUrl="https://captivepath.com/about/"
  jsonLd={aboutSchema}
>
  <!-- Hero -->
  <section class="pt-32 pb-20 md:pt-40 md:pb-26 section-fade-in">
    <div class="max-w-6xl mx-auto px-6 md:px-10">
      <p class="reveal text-xs font-display font-medium tracking-widest uppercase text-teal-800 mb-4">
        About Captive Path
      </p>
      <h1 class="reveal font-display text-4xl sm:text-5xl md:text-6xl text-graphite-900 leading-tight font-bold mb-6 max-w-3xl">
        An independent venture platform built for <span class="text-highlight">serious</span> work.
      </h1>
      <p class="reveal text-graphite-600 text-lg md:text-xl leading-relaxed max-w-2xl">
        Captive Path exists to evaluate, shape and build selected opportunities.
        It is not a consulting firm, an agency, or an accelerator. It is a focused
        platform for the work that sits between vision and execution.
      </p>
    </div>
  </section>

  <WhatWeDo />
  <WhoItsFor />

  <!-- Founder Section -->
  <section class="py-22 md:py-30 bg-graphite-900 text-stone-100 relative overflow-hidden">
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.3) 1px, transparent 0); background-size: 32px 32px;"></div>

    <div class="relative max-w-6xl mx-auto px-6 md:px-10">
      <!-- Top row: Photo left, headline + text right -->
      <div class="grid grid-cols-1 md:grid-cols-5 gap-12 md:gap-16 items-start mb-14 md:mb-18">
        <div class="reveal md:col-span-2">
          <div class="photo-editorial rounded-sm overflow-hidden">
            <img
              src="/images/zach-warshawsky.webp"
              alt="Zach Warshawsky, Founder of Captive Path"
              class="w-full h-auto object-cover grayscale-[20%] contrast-[1.05]"
              width="600"
              height="600"
              loading="lazy"
            />
          </div>
        </div>

        <div class="md:col-span-3">
          <p class="reveal text-xs font-display font-medium tracking-widest uppercase text-teal-400 mb-4">
            Founder
          </p>
          <h2 class="reveal font-display text-3xl md:text-4xl text-stone-50 leading-tight font-bold mb-8">
            Led by <span class="text-highlight-light">operator judgment.</span>
          </h2>
          <p class="reveal text-stone-300 text-lg leading-relaxed mb-6">
            Captive Path is founded and led by Zach Warshawsky, whose background
            spans technology, operations, systems, growth and venture building.
            The advantage is not just access to tools... it is the ability to
            combine strategic thinking with real execution leverage across modern
            platforms and workflows.
          </p>
          <p class="reveal text-stone-300 text-lg leading-relaxed">
            <strong class="text-stone-100">Zach Warshawsky</strong> is the founder of Captive Path. He is an entrepreneur, operator, and systems thinker with over two decades of experience building and scaling technology and marketing businesses. He co-founded Profitable Media, a marketing technology and growth strategy company, and has spent his career at the intersection of business operations, technology, and strategic execution. Captive Path is the vehicle through which he evaluates and builds ventures that meet his standard for what is worth building seriously.
          </p>
        </div>
      </div>

      <!-- Bottom row: 3 stat boxes left, quote + name right -->
      <div class="grid grid-cols-1 md:grid-cols-5 gap-8 md:gap-16 items-start">
        <div class="reveal md:col-span-3 grid grid-cols-1 sm:grid-cols-3 gap-px bg-graphite-700 border-2 border-graphite-700 rounded-sm overflow-hidden">
          <div class="bg-graphite-800 p-5 md:p-6">
            <span class="block font-display text-2xl md:text-3xl font-bold text-teal-400 mb-1">20+</span>
            <span class="text-stone-400 text-sm leading-snug">Years across technology &amp; operations</span>
          </div>
          <div class="bg-graphite-800 p-5 md:p-6">
            <span class="block font-display text-2xl md:text-3xl font-bold text-teal-400 mb-1">Multi-domain</span>
            <span class="text-stone-400 text-sm leading-snug">Systems, growth, venture building</span>
          </div>
          <div class="bg-graphite-800 p-5 md:p-6">
            <span class="block font-display text-2xl md:text-3xl font-bold text-teal-400 mb-1">Operator-led</span>
            <span class="text-stone-400 text-sm leading-snug">Strategy paired with real execution</span>
          </div>
        </div>

        <div class="reveal md:col-span-2 flex flex-col justify-center">
          <blockquote class="border-l-2 border-teal-700 pl-5 mb-6">
            <p class="text-stone-300 text-lg font-display font-medium italic leading-relaxed">
              "Judgment first. Capability second. Tools third."
            </p>
          </blockquote>
          <span class="text-sm text-teal-400 font-display font-medium tracking-wide">
            Zach Warshawsky
          </span>
        </div>
      </div>

      <!-- Internal links -->
      <div class="reveal mt-14 flex flex-col sm:flex-row gap-4">
        <a href="/process" class="text-sm font-medium text-teal-400 hover:text-teal-300 transition-colors link-underline">
          See the venture evaluation process →
        </a>
        <a href="/contact" class="text-sm font-medium text-teal-400 hover:text-teal-300 transition-colors link-underline">
          Start a conversation →
        </a>
      </div>
    </div>
  </section>

  <FocusAreas />
  <ClosingCTA />
</Layout>
