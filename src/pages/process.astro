---
import Layout from '../layouts/Layout.astro';
import HowItWorks from '../components/HowItWorks.astro';
import FocusAreas from '../components/FocusAreas.astro';
import ClosingCTA from '../components/ClosingCTA.astro';
---

<Layout title="Process — Captive Path" description="How Captive Path works: a structured process from evaluation through execution. Every engagement starts with clarity.">
  <!-- Hero -->
  <section class="pt-32 pb-20 md:pt-40 md:pb-26 section-fade-in">
    <div class="max-w-6xl mx-auto px-6 md:px-10">
      <p class="reveal text-xs font-display font-medium tracking-widest uppercase text-teal-800 mb-4">
        Process
      </p>
      <h1 class="reveal font-display text-4xl sm:text-5xl md:text-6xl text-graphite-900 leading-tight font-bold mb-6 max-w-3xl">
        How Captive Path <span class="text-highlight">works.</span>
      </h1>
      <p class="reveal text-graphite-600 text-lg md:text-xl leading-relaxed max-w-2xl">
        Every engagement starts with clarity. The process is structured to
        separate signal from noise, pressure-test what matters and build
        toward outcomes with real leverage.
      </p>
    </div>
  </section>

  <HowItWorks />

  <!-- Engagement Model -->
  <section class="py-22 md:py-30 section-fade-in border-t border-stone-200">
    <div class="max-w-6xl mx-auto px-6 md:px-10">
      <p class="reveal text-xs font-display font-medium tracking-widest uppercase text-teal-800 mb-4">
        Engagement model
      </p>
      <h2 class="reveal font-display text-3xl md:text-4xl text-graphite-900 leading-tight font-bold mb-6">
        Built for <span class="text-highlight">depth,</span> not volume.
      </h2>
      <p class="reveal text-graphite-600 text-lg leading-relaxed max-w-2xl mb-14">
        Captive Path works with a small number of ventures at any given time.
        This is intentional... the goal is meaningful involvement, not portfolio
        scale. Each engagement receives direct attention, real strategic
        thought and hands-on execution.
      </p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        {[
          {
            title: 'Selective intake',
            body: 'Not every opportunity is the right fit. The evaluation process is designed to identify alignment before commitment.',
          },
          {
            title: 'Structured involvement',
            body: 'Engagement depth scales with the opportunity. Some ventures need strategy support, others need full build capability.',
          },
          {
            title: 'Aligned incentives',
            body: 'The best outcomes happen when interests are aligned. Captive Path structures involvement around shared upside where possible.',
          },
        ].map((item) => (
          <div class="reveal bg-stone-50 border-2 border-graphite-700 rounded-sm p-8 md:p-10 card-lift">
            <h3 class="font-display font-semibold text-graphite-900 text-lg mb-3">
              {item.title}
            </h3>
            <p class="text-graphite-500 text-base leading-relaxed">
              {item.body}
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <FocusAreas />
  <ClosingCTA />
</Layout>
