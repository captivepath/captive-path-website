---
import Layout from '../layouts/Layout.astro';
---

<Layout
  title="Terms of Service | Captive Path"
  description="Read the terms governing use of captivepath.com and related services provided by Captive Path LLC."
  noindex={true}
  ogImage="https://captivepath.com/og/pages/og-home.png"
  twitterImage="https://captivepath.com/og/pages/og-home.png"
  canonicalUrl="https://captivepath.com/terms/"
>
  <section class="pt-32 pb-20 md:pt-40 md:pb-26 section-fade-in">
    <div class="max-w-3xl mx-auto px-6 md:px-10">
      <p class="reveal text-xs font-display font-medium tracking-widest uppercase text-teal-800 mb-4">
        Legal
      </p>
      <h1 class="reveal font-display text-4xl sm:text-5xl text-graphite-900 leading-tight font-bold mb-6">
        Terms of Service
      </h1>
      <p class="reveal text-graphite-500 text-sm mb-12">
        Effective date: April 25, 2026
      </p>

      <div class="reveal space-y-8 text-graphite-700 text-base leading-relaxed">
        <div>
          <h2 class="font-display text-xl font-semibold text-graphite-900 mb-3">1. Acceptance of Terms</h2>
          <p>
