---
interface Props {
  condensed?: boolean;
  expanded?: boolean;
}

const { condensed = false, expanded = false } = Astro.props;

const steps = [
  {
    number: '01',
    title: 'Assess',
    description:
      'Understand the idea, the market, the wedge and the practical upside.',
    expandedHtml:
      'Understand the idea, the market, the wedge and the practical upside. Most ventures fail at this stage without realizing it. The work is honest evaluation against <a href="/journal/the-framework-for-evaluating-venture-stage-ideas/" class="text-teal-800 hover:text-teal-700 transition-colors link-underline">the lenses that actually predict outcomes</a>, not validation theater.',
  },
  {
    number: '02',
    title: 'Refine',
    description:
      'Clarify the strategy, priorities, constraints and execution path.',
    expandedHtml:
      'Clarify the strategy, priorities, constraints and execution path. Refinement is where most teams skip the hardest decisions. What to cut, what to defer and what to commit to early. Done well, it shortens the distance between idea and traction by months.',
  },
  {
    number: '03',
    title: 'Build',
    description:
      'Create the product, systems or infrastructure required to move.',
    expandedHtml:
      'Create the product, systems or infrastructure required to move. Build does not begin until clarity exists. When it does begin, <a href="/journal/systems-over-hustle-why-infrastructure-decides-outcomes/" class="text-teal-800 hover:text-teal-700 transition-colors link-underline">infrastructure decisions are treated with the same rigor as product decisions</a>, because they are.',
  },
  {
    number: '04',
    title: 'Advance',
    description:
      'Continue selectively where the opportunity and alignment are strong.',
    expandedHtml:
      'Continue selectively where the opportunity and alignment are strong. Not every venture should advance into deeper involvement and treating that as a default is a mistake. The decision to keep going is its own evaluation.',
  },
];
---

<section class="pt-10 pb-22 md:pt-14 md:pb-30">
  <div class="max-w-6xl mx-auto px-6 md:px-10">
    <p class="reveal text-xs font-display font-medium tracking-widest uppercase text-teal-800 mb-4">
      How it works
    </p>

    <h2 class="reveal font-display text-4xl md:text-5xl text-graphite-900 leading-tight font-bold mb-6">
      Clarity first. Then <span class="text-highlight">momentum.</span>
    </h2>

    <p class="reveal text-graphite-600 text-lg leading-relaxed max-w-2xl mb-14 md:mb-18">
      The process starts with understanding the opportunity, pressure-testing
      what matters and identifying where real leverage exists. From there,
      Captive Path helps define direction, build the right foundation and
      support the opportunities that justify deeper involvement.
    </p>

    <div class="reveal-stagger">
      {steps.map((step, i) => (
        <div
          class:list={[
            'reveal flex flex-col md:flex-row md:items-start gap-4 md:gap-10 py-8 md:py-10',
            i < steps.length - 1 ? 'border-b border-stone-200' : '',
            i === 0 ? 'border-t border-stone-200' : '',
          ]}
        >
          <span class="text-sm font-display font-medium text-teal-800 tracking-wider md:w-16 shrink-0">
            {step.number}
          </span>
          <div class="flex-1">
            <h3 class="text-xl font-display font-semibold text-graphite-900 mb-2">
              {step.title}
            </h3>
            {expanded ? (
              <p class="text-graphite-500 text-base leading-relaxed max-w-lg" set:html={step.expandedHtml} />
            ) : (
              <p class="text-graphite-500 text-base leading-relaxed max-w-lg">
                {step.description}
              </p>
            )}
          </div>
        </div>
      ))}
    </div>

    {condensed && (
      <div class="reveal mt-10">
        <a
          href="/process/"
          class="text-sm font-medium text-teal-800 hover:text-teal-700 transition-colors link-underline"
        >
          Explore the full process →
        </a>
      </div>
    )}
  </div>
</section>
