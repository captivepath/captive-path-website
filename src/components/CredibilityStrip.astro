---
const pillars = [
  {
    title: 'Independent platform',
    subtitle: 'Owned ventures + selective engagements',
  },
  {
    title: 'Selective opportunities',
    subtitle: 'Judgment before capacity',
  },
  {
    title: 'Serious execution',
    subtitle: 'Strategy, systems, modern build',
  },
];
---

<section class="border-y border-stone-200 section-fade-in">
  <div class="max-w-6xl mx-auto px-6 md:px-10 py-14 md:py-18">
    <div class="reveal-stagger grid grid-cols-1 md:grid-cols-3 gap-8 md:gap-12">
      {pillars.map((pillar) => (
        <div class="reveal">
          <h3 class="font-display text-xl md:text-2xl font-semibold text-graphite-900 mb-2">
            {pillar.title}
          </h3>
          <p class="text-graphite-500 text-base leading-relaxed">
            {pillar.subtitle}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
