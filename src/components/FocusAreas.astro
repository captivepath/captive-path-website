---
const focuses = [
  'Venture shaping and opportunity evaluation',
  'Product and execution strategy',
  'Systems and operating infrastructure',
  'AI-assisted research, planning and build acceleration... used as leverage, not hype',
  'Selective venture support, incubation or partnership',
];
---

<section class="py-22 md:py-30 section-fade-out border-b border-stone-200">
  <div class="max-w-6xl mx-auto px-6 md:px-10">
    <p class="reveal text-xs font-display font-medium tracking-widest uppercase text-teal-800 mb-4">
      Focus areas
    </p>

    <h2 class="reveal font-display text-4xl md:text-5xl text-graphite-900 leading-tight font-bold mb-14 md:mb-18">
      Where Captive Path creates the most <span class="text-highlight">leverage.</span>
    </h2>

    <div class="reveal-stagger">
      {focuses.map((item, i) => (
        <div
          class:list={[
            'reveal flex items-start gap-5 py-6 md:py-7',
            i < focuses.length - 1 ? 'border-b border-stone-200' : '',
            i === 0 ? 'border-t border-stone-200' : '',
          ]}
        >
          <span class="text-teal-700 mt-0.5 shrink-0">
            <svg
              width="20"
              height="20"
              viewBox="0 0 20 20"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              aria-hidden="true"
            >
              <path
                d="M3 10h14M12 5l5 5-5 5"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
              />
            </svg>
          </span>
          <p class="text-graphite-700 text-lg leading-relaxed">
            {item}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>
