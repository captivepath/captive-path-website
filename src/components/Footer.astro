---
const year = new Date().getFullYear();
---

<footer class="border-t border-stone-200 bg-stone-100/40">
  <div class="max-w-6xl mx-auto px-6 md:px-10 py-12 md:py-16">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 md:gap-8 mb-12">
      <!-- Brand -->
      <div class="md:col-span-2">
        <a href="/" class="inline-block">
          <img
            src="/images/cp-logo-black.webp"
            alt="Captive Path"
            class="h-10 w-auto"
            width="536"
            height="158"
          />
        </a>
        <p class="mt-3 text-sm text-graphite-500 leading-relaxed max-w-sm">
          An independent venture platform led by Zach Warshawsky. Built to
          shape, support and advance selected opportunities through strategy,
          systems and modern execution.
        </p>
      </div>

      <!-- Navigation -->
      <div>
        <p class="text-xs font-display font-semibold tracking-widest uppercase text-graphite-400 mb-4">
          Navigate
        </p>
        <div class="flex flex-col gap-2.5">
          <a href="/about/" class="text-sm text-graphite-600 hover:text-graphite-900 transition-colors">About</a>
          <a href="/process/" class="text-sm text-graphite-600 hover:text-graphite-900 transition-colors">Process</a>
          <a href="/journal/" class="text-sm text-graphite-600 hover:text-graphite-900 transition-colors">Journal</a>
          <a href="/contact/" class="text-sm text-graphite-600 hover:text-graphite-900 transition-colors">Contact</a>
        </div>
      </div>

      <!-- Connect -->
      <div>
        <p class="text-xs font-display font-semibold tracking-widest uppercase text-graphite-400 mb-4">
          Connect
        </p>
        <div class="flex flex-col gap-2.5">
          <a href="/contact/" class="text-sm text-graphite-600 hover:text-graphite-900 transition-colors">
            Start a conversation
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-stone-200 pt-8 flex flex-col md:flex-row md:items-center md:justify-between gap-3">
      <p class="text-xs text-graphite-400">
        &copy; {year} Captive Path LLC. All rights reserved.
      </p>
      <div class="flex gap-4">
        <a href="/privacy/" class="text-xs text-graphite-400 hover:text-graphite-600 transition-colors">
          Privacy Policy
        </a>
        <a href="/terms/" class="text-xs text-graphite-400 hover:text-graphite-600 transition-colors">
          Terms of Service
        </a>
      </div>
    </div>
  </div>
</footer>
